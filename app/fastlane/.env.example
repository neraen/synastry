# =============================================================================
# AstroMatch - Fastlane Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Apple Developer
# -----------------------------------------------------------------------------
APPLE_ID=your-apple-id@example.com
APPLE_TEAM_ID=YOUR_TEAM_ID
ITC_TEAM_ID=YOUR_ITC_TEAM_ID

# App Store Connect API (recommended over password auth)
APP_STORE_CONNECT_API_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_API_ISSUER_ID=YOUR_ISSUER_ID
APP_STORE_CONNECT_API_KEY_PATH=./AuthKey_XXXXXX.p8

# -----------------------------------------------------------------------------
# Match (iOS certificates)
# -----------------------------------------------------------------------------
MATCH_GIT_URL=git@github.com:your-org/certificates.git
MATCH_PASSWORD=your-match-password

# -----------------------------------------------------------------------------
# Google Play
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# -----------------------------------------------------------------------------
# Android Signing
# -----------------------------------------------------------------------------
ANDROID_KEYSTORE_PATH=./android/app/release.keystore
ANDROID_KEYSTORE_PASSWORD=your-keystore-password
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password

# -----------------------------------------------------------------------------
# Notifications (optional)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

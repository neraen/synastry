# Copy this file to .env.local and fill in your values
# .env.local is gitignored and contains your local secrets

###> symfony/framework-bundle ###
APP_SECRET=your-secret-here-generate-with-php-bin-console-secrets-generate-keys
###< symfony/framework-bundle ###

###> Astroapi ###
ASTROAPI_API_KEY=your-astroapi-key
###< Astroapi ###

###> OpenAi ###
OPENAI_API_KEY=your-openai-api-key
###< OpenAi ###

###> google oauth ###
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
###< google oauth ###

###> RevenueCat ###
# Secret key (v1) from RC dashboard → Project Settings → API Keys
REVENUECAT_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxx
# Webhook secret — choose a strong password and set the same value in RC dashboard
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret
###< RevenueCat ###